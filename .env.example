# Database
POSTGRES_USER=wealthpilot
POSTGRES_PASSWORD=wealthpilot_dev
POSTGRES_DB=wealthpilot
DATABASE_URL=postgresql://wealthpilot:wealthpilot_dev@localhost:5432/wealthpilot

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI APIs
GEMINI_API_KEY=your-gemini-api-key-here
NEWS_API_KEY=your-newsapi-key-here

# App
APP_ENV=development
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
